@model bibliotekarnia.Models.Loan
@{
    ViewData["Title"] = "Loan Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-arrow-left-right"></i> Loan #@Model.Id</h2>
    <a asp-action="Index" class="btn btn-outline-primary"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Loan Details</span>
                <span class="badge @(Model.IsReturned ? "bg-success" : (Model.IsOverdue ? "bg-danger" : "bg-primary")) fs-6">
                    @Model.Status
                </span>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Book</dt>
                    <dd class="col-sm-8">
                        <a asp-controller="Books" asp-action="Details" asp-route-id="@Model.BookId">
                            @Model.Book.Title
                        </a>
                        <br /><small class="text-muted">by @Model.Book.Author.FullName</small>
                    </dd>
                    <dt class="col-sm-4">Member</dt>
                    <dd class="col-sm-8">
                        <a asp-controller="Members" asp-action="Details" asp-route-id="@Model.MemberId">
                            @Model.Member.FullName
                        </a>
                        <br /><small class="text-muted">@Model.Member.Email</small>
                    </dd>
                    <dt class="col-sm-4">Loaned At</dt>
                    <dd class="col-sm-8">@Model.LoanedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</dd>
                    <dt class="col-sm-4">Due Date</dt>
                    <dd class="col-sm-8 @(Model.IsOverdue ? "text-danger fw-bold" : "")">
                        @Model.DueDate.ToLocalTime().ToString("dd MMM yyyy")
                    </dd>
                    @if (Model.ReturnedAt.HasValue)
                    {
                        <dt class="col-sm-4">Returned At</dt>
                        <dd class="col-sm-8 text-success">
                            @Model.ReturnedAt.Value.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                        </dd>
                    }
                    <dt class="col-sm-4">Processed By</dt>
                    <dd class="col-sm-8">@Model.LoanedByUser.Username</dd>
                </dl>

                @if (!Model.IsReturned)
                {
                    <form asp-action="Return" asp-route-id="@Model.Id" method="post"
                          onsubmit="return confirm('Mark this book as returned?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle"></i> Mark as Returned
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>
