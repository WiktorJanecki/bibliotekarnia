@model bibliotekarnia.Models.Book
@{
    ViewData["Title"] = Model.Title;
    var activeLoans = Model.Loans.Where(l => !l.IsReturned).OrderBy(l => l.LoanedAt).ToList();
    var history = Model.Loans.Where(l => l.IsReturned).OrderByDescending(l => l.ReturnedAt).ToList();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-journal-text"></i> @Model.Title</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
            <i class="bi bi-pencil"></i> Edit
        </a>
        <a asp-action="Index" class="btn btn-outline-primary">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Details</h5>
                <dl class="row mb-0">
                    <dt class="col-sm-5">Author</dt>
                    <dd class="col-sm-7">
                        <a asp-controller="Authors" asp-action="Details" asp-route-id="@Model.AuthorId">
                            @Model.Author.FullName
                        </a>
                    </dd>
                    <dt class="col-sm-5">Genre</dt>
                    <dd class="col-sm-7">@(Model.Genre ?? "—")</dd>
                    <dt class="col-sm-5">Year</dt>
                    <dd class="col-sm-7">@(Model.PublishedYear?.ToString() ?? "—")</dd>
                    <dt class="col-sm-5">ISBN</dt>
                    <dd class="col-sm-7">@(Model.ISBN ?? "—")</dd>
                    <dt class="col-sm-5">Total Copies</dt>
                    <dd class="col-sm-7">@Model.TotalCopies</dd>
                    <dt class="col-sm-5">Available</dt>
                    <dd class="col-sm-7">
                        <strong class="@(Model.AvailableCopies == 0 ? "text-danger" : "text-success")">
                            @Model.AvailableCopies
                        </strong>
                    </dd>
                </dl>
            </div>
        </div>
        @if (Model.AvailableCopies > 0)
        {
            <a asp-controller="Loans" asp-action="Create" asp-route-bookId="@Model.Id" class="btn btn-success w-100">
                <i class="bi bi-arrow-right-circle"></i> Create Loan
            </a>
        }
    </div>
    <div class="col-md-8">
        <h5>Active Loans (@activeLoans.Count)</h5>
        @if (activeLoans.Any())
        {
            <table class="table table-sm table-striped mb-4">
                <thead class="table-light">
                    <tr>
                        <th>Member</th>
                        <th>Loaned</th>
                        <th>Due</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var loan in activeLoans)
                    {
                        <tr class="@(loan.IsOverdue ? "table-danger" : "")">
                            <td>
                                <a asp-controller="Members" asp-action="Details" asp-route-id="@loan.MemberId">
                                    @loan.Member.FullName
                                </a>
                            </td>
                            <td>@loan.LoanedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                            <td>@loan.DueDate.ToLocalTime().ToString("dd MMM yyyy")</td>
                            <td>
                                <span class="badge @(loan.IsOverdue ? "bg-danger" : "bg-primary")">
                                    @loan.Status
                                </span>
                            </td>
                            <td>
                                <a asp-controller="Loans" asp-action="Details" asp-route-id="@loan.Id" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">No active loans.</p>
        }

        @if (history.Any())
        {
            <h5>Loan History (@history.Count)</h5>
            <table class="table table-sm table-striped">
                <thead class="table-light">
                    <tr>
                        <th>Member</th>
                        <th>Loaned</th>
                        <th>Returned</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var loan in history.Take(10))
                    {
                        <tr>
                            <td>@loan.Member.FullName</td>
                            <td>@loan.LoanedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                            <td>@loan.ReturnedAt!.Value.ToLocalTime().ToString("dd MMM yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
