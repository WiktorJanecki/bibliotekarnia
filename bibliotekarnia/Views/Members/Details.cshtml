@model bibliotekarnia.Models.Member
@{
    ViewData["Title"] = Model.FullName;
    var activeLoans = Model.Loans.Where(l => !l.IsReturned).OrderBy(l => l.LoanedAt).ToList();
    var pastLoans = Model.Loans.Where(l => l.IsReturned).OrderByDescending(l => l.ReturnedAt).ToList();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-person-circle"></i> @Model.FullName</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
            <i class="bi bi-pencil"></i> Edit
        </a>
        <a asp-action="Index" class="btn btn-outline-primary">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Member Info</h5>
                <dl class="row mb-0">
                    <dt class="col-sm-5">Email</dt>
                    <dd class="col-sm-7">@Model.Email</dd>
                    <dt class="col-sm-5">Phone</dt>
                    <dd class="col-sm-7">@(Model.Phone ?? "—")</dd>
                    <dt class="col-sm-5">Member Since</dt>
                    <dd class="col-sm-7">@Model.MemberSince.ToLocalTime().ToString("dd MMM yyyy")</dd>
                    <dt class="col-sm-5">Total Loans</dt>
                    <dd class="col-sm-7">@Model.Loans.Count</dd>
                    <dt class="col-sm-5">Active</dt>
                    <dd class="col-sm-7"><span class="badge bg-primary">@activeLoans.Count</span></dd>
                </dl>
            </div>
        </div>
        <a asp-controller="Loans" asp-action="Create" asp-route-memberId="@Model.Id" class="btn btn-success w-100">
            <i class="bi bi-plus-circle"></i> Create Loan
        </a>
    </div>
    <div class="col-md-8">
        <h5>Active Loans (@activeLoans.Count)</h5>
        @if (activeLoans.Any())
        {
            <table class="table table-sm table-striped mb-4">
                <thead class="table-light">
                    <tr><th>Book</th><th>Due</th><th>Status</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var loan in activeLoans)
                    {
                        <tr class="@(loan.IsOverdue ? "table-danger" : "")">
                            <td>
                                <a asp-controller="Books" asp-action="Details" asp-route-id="@loan.BookId">
                                    @loan.Book.Title
                                </a>
                            </td>
                            <td>@loan.DueDate.ToLocalTime().ToString("dd MMM yyyy")</td>
                            <td>
                                <span class="badge @(loan.IsOverdue ? "bg-danger" : "bg-primary")">@loan.Status</span>
                            </td>
                            <td>
                                <a asp-controller="Loans" asp-action="Details" asp-route-id="@loan.Id" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else { <p class="text-muted">No active loans.</p> }

        @if (pastLoans.Any())
        {
            <h5>Past Loans (@pastLoans.Count)</h5>
            <table class="table table-sm table-striped">
                <thead class="table-light">
                    <tr><th>Book</th><th>Loaned</th><th>Returned</th></tr>
                </thead>
                <tbody>
                    @foreach (var loan in pastLoans.Take(10))
                    {
                        <tr>
                            <td>@loan.Book.Title</td>
                            <td>@loan.LoanedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                            <td>@loan.ReturnedAt!.Value.ToLocalTime().ToString("dd MMM yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
