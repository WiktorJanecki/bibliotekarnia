@{
    var username = Context.Session.GetString("Username");
    var isAdmin = Context.Session.GetString("IsAdmin") == "true";
    var isLoggedIn = !string.IsNullOrEmpty(username);
}

<nav class="navbar navbar-expand-lg navbar-dark bg-primary fixed-top">
    <div class="container">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">
            <i class="bi bi-book-half"></i> Bibliotekarnia
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarMain">
            @if (isLoggedIn)
            {
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Books" asp-action="Index">
                            <i class="bi bi-journals"></i> Books
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Authors" asp-action="Index">
                            <i class="bi bi-person-lines-fill"></i> Authors
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Members" asp-action="Index">
                            <i class="bi bi-people-fill"></i> Members
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Loans" asp-action="Index">
                            <i class="bi bi-arrow-left-right"></i> Loans
                        </a>
                    </li>
                    @if (isAdmin)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Users" asp-action="Index">
                                <i class="bi bi-shield-lock-fill"></i> Users
                            </a>
                        </li>
                    }
                </ul>
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle"></i> @username
                            @if (isAdmin) { <span class="badge bg-warning text-dark ms-1">Admin</span> }
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <form asp-controller="Auth" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="bi bi-box-arrow-right"></i> Logout
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </li>
                </ul>
            }
            else
            {
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Auth" asp-action="Login">
                            <i class="bi bi-box-arrow-in-right"></i> Login
                        </a>
                    </li>
                </ul>
            }
        </div>
    </div>
</nav>
