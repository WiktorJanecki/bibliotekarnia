@model IEnumerable<bibliotekarnia.Models.User>
@{
    ViewData["Title"] = "User Management";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-shield-lock-fill"></i> User Management</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-person-plus-fill"></i> Add User
    </a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Username</th>
                <th>Role</th>
                <th>Created</th>
                <th>API Token</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @{
                var currentUserId = Context.Session.GetString("UserId");
            }
            @foreach (var user in Model)
            {
                <tr>
                    <td class="fw-bold">
                        @user.Username
                        @if (user.Id.ToString() == currentUserId)
                        {
                            <span class="badge bg-info text-dark ms-1">You</span>
                        }
                    </td>
                    <td>
                        @if (user.IsAdmin)
                        {
                            <span class="badge bg-warning text-dark"><i class="bi bi-shield-fill"></i> Admin</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Staff</span>
                        }
                    </td>
                    <td>@user.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                    <td>
                        <code class="small" id="token-@user.Id">@user.ApiToken[..8]…</code>
                        <button class="btn btn-sm btn-link p-0 ms-1"
                                onclick="document.getElementById('token-@user.Id').textContent = '@user.ApiToken'"
                                title="Reveal full token">
                            <i class="bi bi-eye"></i>
                        </button>
                    </td>
                    <td class="text-end">
                        <form asp-action="RegenerateToken" asp-route-id="@user.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Regenerate API token for @user.Username?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-warning" title="Regenerate token">
                                <i class="bi bi-arrow-clockwise"></i>
                            </button>
                        </form>
                        @if (user.Id.ToString() != currentUserId)
                        {
                            <form asp-action="Delete" asp-route-id="@user.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete user @user.Username?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
